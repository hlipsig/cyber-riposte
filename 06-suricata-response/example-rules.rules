# Example custom rules the agent might generate

# DNS exfiltration — oversized TXT queries in bursts
alert dns any any -> any any ( \
    msg:"cyber-riposte: possible DNS exfil - oversized TXT query burst"; \
    dns.query; content:"."; depth:1; byte_test:1,>,50,0,relative; \
    threshold:type both, track by_src, count 10, seconds 60; \
    classtype:bad-unknown; \
    sid:9000001; rev:1; \
)

# Beaconing — regular-interval HTTPS connections to a single destination
alert tls any any -> any any ( \
    msg:"cyber-riposte: possible C2 beaconing - regular interval TLS"; \
    flow:to_server,established; \
    threshold:type both, track by_src, count 30, seconds 300; \
    classtype:trojan-activity; \
    sid:9000002; rev:1; \
)

# Internal port scan — single source hitting many ports
alert tcp any any -> $HOME_NET any ( \
    msg:"cyber-riposte: internal port scan detected"; \
    flags:S; \
    threshold:type both, track by_src, count 50, seconds 10; \
    classtype:attempted-recon; \
    sid:9000003; rev:1; \
)
